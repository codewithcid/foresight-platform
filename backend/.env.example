# Copy to backend/.env and fill in. Everything has a graceful fallback, so the
# app boots even with nothing set — but channels/LLM features need their keys.

# --- LLM (generation + agent tool-calling) ---
GROQ_API_KEY=                 # groq.com — drafts, briefs, summaries (free tier)
GROQ_MODEL=llama-3.1-8b-instant
# NVIDIA NIM pool (build.nvidia.com) — high-quality generation + Supervisor tool-calling
NVIDIA_API_KEY_QWEN=
NVIDIA_API_KEY_LLAMA=
NVIDIA_API_KEY_GPTOSS=
NVIDIA_API_KEY_NEMOTRON=

# --- Real channels ---
# Twilio (twilio.com) — SMS + WhatsApp. Trial sends only to VERIFIED numbers.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=              # your Twilio number, e.g. +1XXXXXXXXXX
# TWILIO_WHATSAPP_FROM=       # optional; unset uses Twilio's free WhatsApp sandbox (whatsapp:+14155238886)

# Slack (api.slack.com/apps) — ops alerts + human-in-the-loop approval cards.
SLACK_BOT_TOKEN=             # xoxb-… bot token with chat:write
SLACK_CHANNEL=               # #channel or channel id the bot can post to

# Email via Resend (resend.com) — real transactional email.
RESEND_API_KEY=              # re_… ; without RESEND_FROM, sends only to your verified inbox
# RESEND_FROM=Foresight <you@yourdomain.com>   # a verified-domain sender for arbitrary recipients

# Telegram (free) — create a bot via @BotFather; message it once so it can reply.
TELEGRAM_BOT_TOKEN=          # 123456:ABC… from BotFather
# TELEGRAM_CHAT_ID=          # default recipient chat id (else pass it as the 'to' on a test send)

# --- Optional ---
PEXELS_API_KEY=              # product imagery (unused after the v2 refactor; safe to omit)
# FORESIGHT_DB=/var/data/foresight.db   # SQLite path override (point at a persistent disk in prod)
